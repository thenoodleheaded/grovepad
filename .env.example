# Supabase credentials — fill these in from your project's dashboard
# (Settings → API). The app runs local-only until both are set.
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional — lets the document-import feature skip the in-app key prompt.
# GPT-5 family only (gpt-5 / gpt-5-mini).
VITE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY
