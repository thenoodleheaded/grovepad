# Locally generated signing material — keystores, certs, and their
# passwords. Never committed; back these up outside the repo instead.
/secrets/

# Native build output and prebuilt binaries — regenerated by Gradle/Xcode.
# Only the hand-written sources under gen/**/src and native/** are tracked.
src-tauri/gen/android/build/
src-tauri/gen/android/app/build/
src-tauri/gen/android/.gradle/
src-tauri/gen/android/buildSrc/.gradle/
src-tauri/gen/android/buildSrc/build/
src-tauri/gen/apple/Externals/
src-tauri/native/apple/build/

# Local business documents that live in this folder but not in code history.
/grovepad_*.pdf

# Benchmark run artifacts — blessed baselines are copied to bench/baselines/.
/bench/results/
