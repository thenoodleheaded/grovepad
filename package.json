{
  "name": "grovepad",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "oxlint",
    "test": "vitest run",
    "test:focus": "vitest run src/utils/focusModeReorder.test.ts src/utils/focusModeSizing.test.ts",
    "docs:check": "node scripts/check-codebase-map.mjs",
    "db:check": "node scripts/check-supabase-migrations.mjs",
    "bench:canvas": "node scripts/bench-canvas.mjs",
    "check": "npm run typecheck && npm run lint && npm run test && npm run docs:check && npm run db:check",
    "check:full": "npm run build && npm run lint && npm run test && npm run docs:check && npm run db:check",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:macos-widget": "npm run tauri:build",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build --apk --aab",
    "tauri:android:build:debug": "tauri android build --debug --target aarch64 --apk --ci",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "tauri ios build"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@mlc-ai/web-llm": "^0.2.84",
    "@supabase/supabase-js": "^2.110.2",
    "@tauri-apps/api": "^2.11.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.23.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "oxlint": "^1.71.0",
    "pgsql-parser": "^17.9.16",
    "playwright-core": "^1.55.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
